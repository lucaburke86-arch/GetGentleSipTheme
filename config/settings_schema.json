[
  {
    "name": "theme_info",
    "theme_name": "GentleSip",
    "theme_version": "1.0.0",
    "theme_author": "GetGentleSip",
    "theme_documentation_url": "https://shopify.dev/docs/themes",
    "theme_support_url": "https://help.shopify.com"
  },
  {
    "name": "Brand & logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width",
        "min": 80,
        "max": 320,
        "step": 10,
        "unit": "px",
        "default": 150
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Square image, at least 32 x 32 px"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_accent",
        "label": "Gold accent",
        "default": "#C9A14A"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_bg",
        "label": "Page background",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_footer_bg",
        "label": "Footer background",
        "default": "#111111"
      },
      {
        "type": "color",
        "id": "color_footer_text",
        "label": "Footer text",
        "default": "#F2F2F2"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading font",
        "default": "montserrat_n5"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "assistant_n4"
      }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show vendor name",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "card_show_secondary_image",
        "label": "Show second image on hover",
        "default": true
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      }
    ]
  },
  {
    "name": "Cart & checkout",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_payment_icons",
        "label": "Show payment icons in footer",
        "default": true
      }
    ]
  }
]
