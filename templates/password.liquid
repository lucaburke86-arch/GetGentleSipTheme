<div class="password-page">
  {%- if settings.logo != blank -%}
    <img class="password-logo" src="{{ settings.logo | image_url: width: 500 }}" alt="{{ shop.name | escape }}">
  {%- else -%}
    <h1 style="margin-bottom:6px;">{{ shop.name }}</h1>
  {%- endif -%}

  <div class="password-eyebrow">Coming soon</div>
  <h1>We're almost ready to sip</h1>
  <p>{{ shop.name }} — temperature-display bottles that protect sensitive teeth and let you sip in style. Drop your email and we'll tell you the second we launch.</p>

  {%- form 'customer' -%}
    <input type="hidden" name="contact[tags]" value="prelaunch">
    {%- if form.posted_successfully? -%}
      <p class="form-success">Thanks — you'll be first to know!</p>
    {%- else -%}
      <input type="email" name="contact[email]" placeholder="Your email" required aria-label="Email">
      <button type="submit" class="btn">Notify me</button>
    {%- endif -%}
  {%- endform -%}

  <hr style="border:0;border-top:1px solid #444;width:60px;margin:32px 0;">

  <p style="font-size:.85rem;margin-bottom:4px;">Have the store password?</p>
  {%- form 'storefront_password' -%}
    <input type="password" name="password" placeholder="Enter password" aria-label="Store password">
    <button type="submit" class="btn">Enter</button>
  {%- endform -%}
</div>
