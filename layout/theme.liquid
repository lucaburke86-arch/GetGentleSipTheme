<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_accent }}">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {{ content_for_header }}

  {%- liquid
    assign body_font = settings.type_body_font
    assign heading_font = settings.type_header_font
  -%}

  {{ 'base.css' | asset_url | stylesheet_tag }}

  <style>
    {{ body_font | font_face: font_display: 'swap' }}
    {{ heading_font | font_face: font_display: 'swap' }}
    {{ body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
    :root{
      --color-accent: {{ settings.color_accent }};
      --color-accent-dark: {{ settings.color_accent | color_darken: 12 }};
      --color-text: {{ settings.color_text }};
      --color-bg: {{ settings.color_bg }};
      --color-footer-bg: {{ settings.color_footer_bg }};
      --color-footer-text: {{ settings.color_footer_text }};
      --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
      --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
      --font-heading-weight: {{ heading_font.weight }};
      --page-width: 1280px;
    }
  </style>
</head>
<body class="template-{{ request.page_type | handle }}">
  <a class="skip-link" href="#MainContent">Skip to content</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
</body>
</html>
