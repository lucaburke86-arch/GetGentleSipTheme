<section class="hero" style="--hero-min:{{ section.settings.height }}vh;">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__glow hero__glow--2" aria-hidden="true"></div>

  {%- if section.settings.image != blank -%}
    <div class="hero__bg">
      <img src="{{ section.settings.image | image_url: width: 2600 }}" alt="" loading="eager" width="2600" height="1500">
    </div>
    <div class="hero__overlay" style="opacity:{{ section.settings.overlay | divided_by: 100.0 }};"></div>
  {%- endif -%}

  <div class="hero__inner page-width">
    <div class="hero__content {% if section.settings.layout == 'center' %}hero__content--center{% endif %}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="hero__title">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank %} <em>{{ section.settings.heading_accent }}</em>{% endif -%}
      </h1>

      {%- if section.settings.text != blank -%}
        <p class="hero__text">{{ section.settings.text }}</p>
      {%- endif -%}

      <div class="hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="btn btn--lg">
            {{ section.settings.button_label }}
            <span class="btn__arrow" aria-hidden="true">&rarr;</span>
          </a>
        {%- endif -%}
        {%- if section.settings.button2_label != blank -%}
          <a href="{{ section.settings.button2_link }}" class="btn btn--ghost btn--lg">{{ section.settings.button2_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- if section.settings.show_scroll -%}
    <button class="hero__scroll" data-hero-scroll type="button" aria-label="Scroll down"><span></span></button>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image", "info": "Optional — leave empty for the animated gold gradient" },
    { "type": "range", "id": "overlay", "label": "Image darken", "min": 0, "max": 90, "step": 5, "unit": "%", "default": 60 },
    { "type": "range", "id": "height", "label": "Height", "min": 60, "max": 100, "step": 1, "unit": "vh", "default": 92 },
    {
      "type": "select", "id": "layout", "label": "Text alignment", "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Sensitive teeth approved" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Know your temperature." },
    { "type": "text", "id": "heading_accent", "label": "Highlighted line", "info": "Shown in gold gradient", "default": "Sip in style." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Smart bottles that show your drink's exact temperature — so every sip is comfortable, never too hot or too cold." },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "Shop bottles" },
    { "type": "url", "id": "button_link", "label": "Primary button link" },
    { "type": "text", "id": "button2_label", "label": "Secondary button", "default": "How it works" },
    { "type": "url", "id": "button2_link", "label": "Secondary button link" },
    { "type": "checkbox", "id": "show_scroll", "label": "Show scroll indicator", "default": true }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
