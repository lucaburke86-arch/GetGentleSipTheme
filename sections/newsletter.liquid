<div class="section section--dark newsletter">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="page-width">
    <div class="newsletter__inner reveal">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow eyebrow--center">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<p style="opacity:.78;">{{ section.settings.text }}</p>{%- endif -%}
      {%- form 'customer' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="form-success">You're on the list — thanks for subscribing!</p>
        {%- else -%}
          <input type="email" name="contact[email]" placeholder="Enter your email" required aria-label="Email">
          <button type="submit" class="btn">{{ section.settings.button_label }}</button>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="form-error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endform -%}
      {%- if section.settings.note != blank -%}
        <p class="newsletter__note">{{ section.settings.note }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Newsletter signup",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the club" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Be first to sip" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Restock alerts, new sizes and subscriber-only discounts — straight to your inbox." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Sign up" },
    { "type": "text", "id": "note", "label": "Small note", "default": "No spam. Unsubscribe anytime." }
  ],
  "presets": [{ "name": "Newsletter signup" }]
}
{% endschema %}
