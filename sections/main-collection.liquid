<div class="section">
  <div class="page-width">
    <div class="collection-head">
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="rte" style="max-width:640px;margin:0 auto;">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    <div class="collection-bar">
      <span>{{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}</span>
      <form method="get" id="sortForm">
        <label for="sortBy" class="visually-hidden">Sort by</label>
        <select name="sort_by" id="sortBy" onchange="document.getElementById('sortForm').submit()">
          {%- assign sort = collection.sort_by | default: collection.default_sort_by -%}
          <option value="manual" {% if sort == 'manual' %}selected{% endif %}>Featured</option>
          <option value="best-selling" {% if sort == 'best-selling' %}selected{% endif %}>Best selling</option>
          <option value="title-ascending" {% if sort == 'title-ascending' %}selected{% endif %}>A–Z</option>
          <option value="title-descending" {% if sort == 'title-descending' %}selected{% endif %}>Z–A</option>
          <option value="price-ascending" {% if sort == 'price-ascending' %}selected{% endif %}>Price: low to high</option>
          <option value="price-descending" {% if sort == 'price-descending' %}selected{% endif %}>Price: high to low</option>
          <option value="created-descending" {% if sort == 'created-descending' %}selected{% endif %}>Newest</option>
        </select>
      </form>
    </div>

    {%- paginate collection.products by 24 -%}
      {%- if collection.products.size > 0 -%}
        <div class="product-grid">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product, index: forloop.index0 %}
          {%- endfor -%}
        </div>
        {% render 'pagination', paginate: paginate %}
      {%- else -%}
        <div class="empty-state">
          <p>No products in this collection yet. Check back soon.</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline">Browse all products</a>
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection page",
  "settings": []
}
{% endschema %}
