<div class="section">
  <div class="page-width{% if page.template_suffix == 'contact' %} text-center{% endif %}" style="max-width:820px;">
    <h1>{{ page.title }}</h1>
    <div class="rte">{{ page.content }}</div>

    {%- if page.template_suffix == 'contact' -%}
      <div style="margin-top:30px;">
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <p class="form-success">Thanks for reaching out — we'll reply soon.</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p class="form-error">{{ form.errors | default_errors }}</p>
          {%- endif -%}
          <div style="display:grid;gap:14px;max-width:520px;margin:0 auto;">
            <input type="text" name="contact[name]" placeholder="Your name" required
                   style="padding:13px;border:1.5px solid #ccc;border-radius:3px;font-family:var(--font-body);">
            <input type="email" name="contact[email]" placeholder="Your email" required
                   style="padding:13px;border:1.5px solid #ccc;border-radius:3px;font-family:var(--font-body);">
            <textarea name="contact[body]" placeholder="How can we help?" rows="5" required
                   style="padding:13px;border:1.5px solid #ccc;border-radius:3px;font-family:var(--font-body);"></textarea>
            <button type="submit" class="btn">Send message</button>
          </div>
        {%- endform -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}
