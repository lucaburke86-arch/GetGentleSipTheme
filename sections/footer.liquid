<footer class="site-footer">
  <div class="page-width">
    <div class="footer__grid">
      <div class="footer__col footer__brand">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 400 }}" alt="{{ shop.name | escape }}" style="max-width:160px;margin-bottom:14px;">
        {%- else -%}
          <h4>{{ shop.name }}</h4>
        {%- endif -%}
        <p>{{ section.settings.about_text }}</p>
        <div class="footer__social">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5"></rect>
                <circle cx="12" cy="12" r="4"></circle><circle cx="17.5" cy="6.5" r="1" fill="currentColor"></circle>
              </svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M16 3c.3 2.1 1.6 3.7 3.8 4v3c-1.4 0-2.7-.4-3.8-1.1V16a6 6 0 1 1-6-6c.3 0 .7 0 1 .1v3.1a3 3 0 1 0 2 2.8V3z"></path>
              </svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M14 9h3V6h-3c-2.2 0-4 1.8-4 4v2H7v3h3v6h3v-6h3l1-3h-4v-2c0-.6.4-1 1-1z"></path>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="footer__col">
        <h4>{{ section.settings.menu_title }}</h4>
        <ul>
          {%- for link in section.settings.menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="footer__col footer__newsletter">
        <h4>{{ section.settings.newsletter_title }}</h4>
        <p style="font-size:.9rem;opacity:.8;">{{ section.settings.newsletter_text }}</p>
        {%- form 'customer' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <p class="form-success">Thanks for subscribing!</p>
          {%- else -%}
            <input type="email" name="contact[email]" placeholder="Your email" required aria-label="Email">
            <button type="submit" class="btn btn--full">Subscribe</button>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>

    <div class="footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      {%- if settings.show_payment_icons and shop.enabled_payment_types.size > 0 -%}
        <div class="footer__payment">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "about_text",
      "label": "About text",
      "default": "GetGentleSip — temperature-display bottles that protect sensitive teeth and let you sip in style."
    },
    {
      "type": "text",
      "id": "menu_title",
      "label": "Menu column title",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter title",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Get launch news, drops and discounts."
    }
  ]
}
{% endschema %}
