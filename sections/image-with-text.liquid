<div class="section section--cream">
  <div class="page-width">
    <div class="image-text {% if section.settings.flip %}image-text--flip{% endif %}">
      <div class="image-text__media reveal">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1300 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
      <div class="image-text__content reveal" style="transition-delay:120ms">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
        <div class="rte">{{ section.settings.text }}</div>
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn" style="margin-top:8px;">
            {{ section.settings.button_label }}<span class="btn__arrow" aria-hidden="true">&rarr;</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "checkbox", "id": "flip", "label": "Show image on the right", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The science of a good sip" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How the temperature display works" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>The bottle's smart band reacts to your drink and shows the temperature instantly. No more guessing, no more burnt tongues or sensitive-teeth shock — just comfortable sipping every time.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Image with text" }]
}
{% endschema %}
