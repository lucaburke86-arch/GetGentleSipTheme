<div class="section">
  <div class="page-width">
    <div class="section__head reveal">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow eyebrow--center">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.subheading != blank -%}<p>{{ section.settings.subheading }}</p>{%- endif -%}
    </div>

    {%- assign coll = collections[section.settings.collection] -%}
    {%- if coll != blank and coll.products.size > 0 -%}
      <div class="product-grid">
        {%- for product in coll.products limit: section.settings.limit -%}
          {% render 'product-card', product: product, index: forloop.index0 %}
        {%- endfor -%}
      </div>
      {%- if section.settings.show_view_all -%}
        <div class="text-center reveal" style="margin-top:44px;">
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--outline">View all<span class="btn__arrow" aria-hidden="true">&rarr;</span></a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="empty-state">
        <p>Select a collection in the theme editor to display products here.</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop the drop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "The bottles everyone's sipping from." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 4, "max": 12, "step": 4, "default": 8 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View all' button", "default": true }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}
